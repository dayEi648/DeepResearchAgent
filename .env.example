# LLM API（默认 DeepSeek，兼容 OpenAI 格式）
DEEPSEEK_API_KEY=sk-xxx
# OPENAI_API_KEY=sk-xxx
# ZHIPU_API_KEY=xxx

# 阿里云百炼 API（用于 text-embedding-v4 向量模型，免费额度）
DASHSCOPE_API_KEY=sk-xxx

# 阿里云 IQS Search API（请替换为你的实际 Key）
IQSSEARCH_API_KEY=xxx

# Redis
REDIS_URL=redis://localhost:6379/0

# 并发限流
MAX_CONCURRENT_RESEARCH=5

# 超时设置（秒）
AGENT_NODE_TIMEOUT=60

# 阿里云 OSS（报告存储，线上部署必填）
# 说明：Bucket 建议设置公共读策略，或只允许 reports/ 前缀公共读
OSS_BUCKET_NAME=your-bucket-name
OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
OSS_ACCESS_KEY_ID=your-access-key-id
OSS_ACCESS_KEY_SECRET=your-access-key-secret
OSS_REPORT_PREFIX=reports